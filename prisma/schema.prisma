// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        Int      @id @default(autoincrement())
  admitadId String   @unique      // لمنع تكرار نفس المنتج
  name      String
  url       String                // رابط الأفلييت (Affiliate Link)
  image     String?               // رابط صورة المنتج
  price     String?               @default("عرض خاص")
  updatedAt DateTime @updatedAt
}
