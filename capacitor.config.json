{
  "appId": "com.raqqa.app",
  "appName": "رقة",
  "webDir": "dist_web",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "raw.githubusercontent.com"
    ]
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#445271"
    },
    "CapacitorUpdater": {
      "autoUpdate": false
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "buildOptions": {
      "releaseKeystore": "roqa_release.jks",
      "releaseKeyAlias": "roqa_alias"
    }
  }
}
