{
  "appId": "com.raqqa.app",
  "appName": "رقة",
  "webDir": "dist_web",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "raw.githubusercontent.com",
      "raqqa-ruddy.vercel.app",
      "raqqa-hjl8.vercel.app"
    ]
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#445271"
    },
    "CapacitorUpdater": {
      "autoUpdate": false
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true
  }
}
