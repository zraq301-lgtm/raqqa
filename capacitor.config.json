{
  "appId": "com.raqqa.app",
  "appName": "رقة",
  "webDir": "dist_web",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": []
  },
  "plugins": {
    "LiveUpdates": {
      "appId": "raqqa-native-1",
      "channel": "Production",
      "autoUpdateMethod": "background",
      "maxVersions": 3
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#445271"
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "buildOptions": {
      "releaseKeystore": "roqa_release.jks",
      "releaseKeyAlias": "roqa_alias"
    }
  }
}
