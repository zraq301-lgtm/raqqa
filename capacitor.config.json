{
  "appId": "com.raqqa.app",
  "appName": "Roqa",
  "webDir": "dist_web",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"],
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "buildOptions": {
      "release": {
        "signingConfig": "release"
      }
    }
  },
  "plugins": {
    "CapacitorUpdater": {
      "appId": "71ca3dbf-f065-4a17-980a-cde8e32a5296"
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#445271",
      "sound": "beep.wav"
    },
    "FirebaseMessaging": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "OneSignal": {
      "appId": "726fe629-0b1e-4294-9a4b-39cf50212b42"
    },
    "Geolocation": {
      "enabled": true
    }
  }
}
