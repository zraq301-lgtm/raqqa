{
  "appId": "com.raqqa.app",
  "appName": "رقة",
  "webDir": "dist_web",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_name",
      "iconColor": "#FFC0CB"
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "AdMob": {
      "initializeOnStartup": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
